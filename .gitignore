# =====================================================================
# Python
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg

# =====================================================================
# Virtual environments
# =====================================================================
.venv/
venv/
env/
ENV/

# =====================================================================
# Testing / linting / typing caches
# =====================================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# =====================================================================
# Pipeline data and state
# ---------------------------------------------------------------------
# Sample fixtures under data/sample/ ARE committed (small, deterministic,
# needed for tests and the docker-compose smoke run). Everything else
# under data/ is generated at runtime and must not be in git.
# =====================================================================
data/day1/*
data/day2/*
data/lake/
data/dq_reports/
data/metadata.db
data/metadata.db-wal
data/metadata.db-shm
!data/day1/.gitkeep
!data/day2/.gitkeep
!data/sample/

# =====================================================================
# Kaggle credentials — must never be committed
# =====================================================================
kaggle.json
.kaggle/

# =====================================================================
# Secrets / local config overrides
# =====================================================================
.env
.env.local
*.pem
*.key

# =====================================================================
# Docker / Airflow runtime artefacts
# =====================================================================
logs/
plugins/
airflow.cfg
airflow.db
webserver_config.py
# Local airflow standalone state: SQLite DB, admin password,
# generated configs, task logs. Created when AIRFLOW_HOME=$(pwd)/.airflow
# is set per README. NEVER commit — contains the auto-generated
# admin password and runtime task data.
.airflow/
simple_auth_manager_passwords.json.generated
standalone_admin_password.txt

# =====================================================================
# Editors / OS
# =====================================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
